# ==============================================================================
# SkillUP Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ------------------------------------------------------------------------------
# OpenAI Configuration
# ------------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------------------------
# Neo4j Knowledge Graph Configuration
# ------------------------------------------------------------------------------
# Neo4j connection details for the knowledge graph
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ------------------------------------------------------------------------------
# Databricks Configuration (Optional - for production deployment)
# ------------------------------------------------------------------------------
# Only required if deploying on Databricks
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_CLIENT_ID=your_client_id
# DATABRICKS_CLIENT_SECRET=your_client_secret

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
# LLM Model Selection (gpt-3.5-turbo or gpt-4o-mini)
LLM_MODEL=gpt-3.5-turbo

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ------------------------------------------------------------------------------
# Data Pipeline Configuration (Optional)
# ------------------------------------------------------------------------------
# Unity Catalog names for Databricks tables
# CATALOG_NAME=workspace
# JD_TABLE=workspace.default.job_description
# PEER_TABLE=workspace.default.resume_dataset_1200
# COURSE_TABLE=workspace.default.my_skills_future_course_directory
# KG_OUTPUT_TABLE=workspace.default.knowledge_graph_output
